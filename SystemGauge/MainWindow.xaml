<Window x:Class="SystemGauge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="mer4t - System Gauge"
        Width="1600"
        Height="720"
        MinWidth="900"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="#030303"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>

        <Style x:Key="LinearGaugeStyle"
               TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="TickScaleTemplate"
                         TargetType="{x:Type Control}">
            <UniformGrid Columns="21">
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="1" Height="6" Background="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                <Border Width="2" Height="10" Background="#D8D8D8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
            </UniformGrid>
        </ControlTemplate>

        <ControlTemplate x:Key="GaugeFaceTemplate"
                         TargetType="{x:Type Control}">
            <Canvas Width="360" Height="360">
                <Path Data="M 180,325 A 145,145 0 1 1 325,180"
                      Stroke="#280707"
                      StrokeThickness="17"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>

                <Path Data="M 180,325 A 145,145 0 1 1 325,180"
                      Stroke="#E50914"
                      StrokeThickness="9"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>

                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="180" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="193.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="207" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="220.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="234" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="247.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="261" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="274.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="288" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="301.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="315" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="328.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="342" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="355.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="369" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="382.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="396" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="409.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="423" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="60" Stroke="#858585" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="436.5" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>
                <Line X1="180" Y1="48" X2="180" Y2="72" Stroke="#F2F2F2" StrokeThickness="4">
                    <Line.RenderTransform>
                        <RotateTransform Angle="450" CenterX="180" CenterY="180"/>
                    </Line.RenderTransform>
                </Line>

                <TextBlock Text="0" Canvas.Left="158" Canvas.Top="265" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="10" Canvas.Left="114" Canvas.Top="254" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="20" Canvas.Left="80" Canvas.Top="225" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="30" Canvas.Left="63" Canvas.Top="184" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="40" Canvas.Left="67" Canvas.Top="139" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="50" Canvas.Left="90" Canvas.Top="101" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="60" Canvas.Left="128" Canvas.Top="78" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="70" Canvas.Left="173" Canvas.Top="74" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="80" Canvas.Left="214" Canvas.Top="91" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="90" Canvas.Left="244" Canvas.Top="125" Width="44" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
                <TextBlock Text="100" Canvas.Left="251" Canvas.Top="169" Width="50" TextAlignment="Center" Foreground="#A5A5A5" FontSize="15"/>
            </Canvas>
        </ControlTemplate>

        <Style x:Key="DarkCardBorderStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#070707"/>
            <Setter Property="BorderBrush" Value="#310A0A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
        </Style>


        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SettingsButtonStyle"
               TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="#979797"/>
            <Setter Property="Background" Value="#0C0C0C"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#151515"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#454545"/>
                                <Setter Property="Foreground" Value="#C5C5C5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#171010"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#5A1519"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSwitchStyle"
               TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="SwitchTrack"
                                Width="48"
                                Height="26"
                                Background="#202020"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                CornerRadius="13">
                            <Ellipse x:Name="SwitchKnob"
                                     Width="18"
                                     Height="18"
                                     Margin="3"
                                     HorizontalAlignment="Left"
                                     Fill="#8A8A8A"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#5B5B5B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#4D1014"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#A91B24"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#E50914"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#030303">
        <Viewbox Stretch="Uniform"
                 StretchDirection="Both"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">

            <Border Width="1600"
                    Height="680"
                    CornerRadius="34"
                    Background="#090909"
                    BorderBrush="#3A0A0A"
                    BorderThickness="2">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="35"
                                      ShadowDepth="0"
                                      Opacity="0.8"
                                      Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="500"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>

                    <ToggleButton x:Name="SettingsButton"
                                  Grid.RowSpan="2"
                                  Panel.ZIndex="100"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Margin="0,20,24,0"
                                  Style="{StaticResource SettingsButtonStyle}"
                                  ToolTip="Ayarlar">
                        <TextBlock Text="⚙"
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="22"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </ToggleButton>

                    <Border Grid.RowSpan="2"
                            Panel.ZIndex="99"
                            Width="360"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,70,24,0"
                            Padding="19"
                            Background="#0B0B0B"
                            BorderBrush="#481014"
                            BorderThickness="1"
                            CornerRadius="15"
                            Visibility="{Binding IsChecked, ElementName=SettingsButton, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="22"
                                              ShadowDepth="3"
                                              Opacity="0.75"
                                              Color="Black"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="AYARLAR"
                                       Foreground="#A7A7A7"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="2,0,0,17"/>

                            <Grid Margin="2,0,2,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,18,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Windows ile başlat"
                                               Foreground="#E4E4E4"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Oturum açıldığında gizli simgelerde başlar"
                                               Margin="0,4,0,0"
                                               Foreground="#777777"
                                               FontSize="11"/>
                                </StackPanel>

                                <ToggleButton x:Name="StartWithWindowsToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource SettingsSwitchStyle}"
                                              Click="StartWithWindowsToggle_Click"/>
                            </Grid>

                            <Border Height="1"
                                    Margin="0,0,0,15"
                                    Background="#242424"/>

                            <Grid Margin="2,0,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,18,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Çarpıda simge durumuna küçült"
                                               Foreground="#E4E4E4"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Kapalıysa çarpıya basınca uygulama kapanır"
                                               Margin="0,4,0,0"
                                               Foreground="#777777"
                                               FontSize="11"/>
                                </StackPanel>

                                <ToggleButton x:Name="CloseToTrayToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource SettingsSwitchStyle}"
                                              Click="CloseToTrayToggle_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- CPU SIDE -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="105"/>
                                <RowDefinition Height="395"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="CpuNameText"
                                       Grid.Row="0"
                                       Text="CPU"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="55,0,0,10"
                                       Foreground="#8C8C8C"
                                       FontSize="19"
                                       FontWeight="SemiBold"/>

                            <Grid Grid.Row="1"
                                  Width="760"
                                  HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="430"/>
                                    <ColumnDefinition Width="330"/>
                                </Grid.ColumnDefinitions>

                                <Canvas Grid.Column="0"
                                        Width="360"
                                        Height="360"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Control Width="360"
                                             Height="360"
                                             Template="{StaticResource GaugeFaceTemplate}"/>

                                    <Line x:Name="CpuNeedle"
                                          X1="180"
                                          Y1="180"
                                          X2="180"
                                          Y2="79"
                                          StrokeThickness="7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.Stroke>
                                            <SolidColorBrush x:Name="CpuNeedleBrush" Color="#00C853"/>
                                        </Line.Stroke>
                                        <Line.RenderTransform>
                                            <RotateTransform Angle="180" CenterX="180" CenterY="180"/>
                                        </Line.RenderTransform>
                                    </Line>

                                    <Ellipse Width="38" Height="38" Canvas.Left="161" Canvas.Top="161" Fill="#E50914" Stroke="#FF5962" StrokeThickness="4"/>
                                    <Ellipse Width="14" Height="14" Canvas.Left="173" Canvas.Top="173" Fill="#090909"/>

                                    <TextBlock Text="CPU"
                                               Canvas.Left="190"
                                               Canvas.Top="310"
                                               Width="75"
                                               Foreground="#9A9A9A"
                                               FontSize="23"
                                               FontWeight="SemiBold"/>
                                </Canvas>

                                <StackPanel Grid.Column="1"
                                            Margin="4,10,24,10"
                                            VerticalAlignment="Center">

                                    <Border Style="{StaticResource DarkCardBorderStyle}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="SICAKLIK" Foreground="#999999" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="CpuTemperatureText" Text="-- °C" HorizontalAlignment="Right" Foreground="#F2F2F2" FontSize="18" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Height="28" Margin="0,14,0,0">
                                                <Control Height="10" VerticalAlignment="Top" Template="{StaticResource TickScaleTemplate}"/>
                                                <ProgressBar x:Name="CpuTemperatureBar" Minimum="0" Maximum="100" Value="0" Height="10" VerticalAlignment="Bottom" Style="{StaticResource LinearGaugeStyle}">
                                                    <ProgressBar.Foreground>
                                                        <SolidColorBrush x:Name="CpuTemperatureBrush" Color="#00C853"/>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DarkCardBorderStyle}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="SAAT HIZI" Foreground="#999999" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="CpuClockText" Text="-- GHz" HorizontalAlignment="Right" Foreground="#F2F2F2" FontSize="18" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Height="28" Margin="0,14,0,0">
                                                <Control Height="10" VerticalAlignment="Top" Template="{StaticResource TickScaleTemplate}"/>
                                                <ProgressBar x:Name="CpuClockBar" Minimum="0" Maximum="100" Value="0" Height="10" VerticalAlignment="Bottom" Style="{StaticResource LinearGaugeStyle}">
                                                    <ProgressBar.Foreground>
                                                        <SolidColorBrush x:Name="CpuClockBrush" Color="#00C853"/>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DarkCardBorderStyle}">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="FAN HIZI" Foreground="#999999" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="CpuFanText" Text="-- RPM" HorizontalAlignment="Right" Foreground="#F2F2F2" FontSize="18" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Height="28" Margin="0,14,0,0">
                                                <Control Height="10" VerticalAlignment="Top" Template="{StaticResource TickScaleTemplate}"/>
                                                <ProgressBar x:Name="CpuFanBar" Minimum="0" Maximum="100" Value="0" Height="10" VerticalAlignment="Bottom" Style="{StaticResource LinearGaugeStyle}">
                                                    <ProgressBar.Foreground>
                                                        <SolidColorBrush x:Name="CpuFanBrush" Color="#00C853"/>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Border Grid.Column="1" Width="1" Margin="0,24" Background="#351010"/>

                        <!-- GPU SIDE -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="105"/>
                                <RowDefinition Height="395"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="GpuNameText"
                                       Grid.Row="0"
                                       Text="GPU"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="55,0,0,10"
                                       Foreground="#8C8C8C"
                                       FontSize="19"
                                       FontWeight="SemiBold"/>

                            <Grid Grid.Row="1"
                                  Width="760"
                                  HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="430"/>
                                    <ColumnDefinition Width="330"/>
                                </Grid.ColumnDefinitions>

                                <Canvas Grid.Column="0"
                                        Width="360"
                                        Height="360"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Control Width="360"
                                             Height="360"
                                             Template="{StaticResource GaugeFaceTemplate}"/>

                                    <Line x:Name="GpuNeedle"
                                          X1="180"
                                          Y1="180"
                                          X2="180"
                                          Y2="79"
                                          StrokeThickness="7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.Stroke>
                                            <SolidColorBrush x:Name="GpuNeedleBrush" Color="#00C853"/>
                                        </Line.Stroke>
                                        <Line.RenderTransform>
                                            <RotateTransform Angle="180" CenterX="180" CenterY="180"/>
                                        </Line.RenderTransform>
                                    </Line>

